{
  "name": "pip-token",
  "displayName": "Pip-Token",
  "description": "Track your Claude Code token usage with a Fallout Pip-Boy aesthetic",
  "version": "0.1.0",
  "publisher": "studiozedward",
  "license": "MIT",
  "icon": "assets/icon.png",
  "author": "studiozedward",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "usage",
    "tracking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/studiozedward/pip-token"
  },
  "bugs": {
    "url": "https://github.com/studiozedward/pip-token/issues"
  },
  "homepage": "https://github.com/studiozedward/pip-token#readme",
  "contributes": {
    "commands": [
      {
        "command": "pipToken.openPanel",
        "title": "Pip-Token: Open Panel"
      },
{
        "command": "pipToken.syncDashboard",
        "title": "Pip-Token: Sync Dashboard"
      }
    ]
  },
  "activationEvents": ["onStartupFinished"],
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest run",
    "package": "npm run build && vsce package",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
